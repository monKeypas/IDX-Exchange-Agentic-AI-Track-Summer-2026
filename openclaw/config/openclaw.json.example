{
  "agents": {
    "defaults": {
      "workspace": "/path/to/IDX-Exchange-Agentic-AI-Track-Summer-2026/openclaw/workspace",
      "models": {
        "openai/gpt-5.5": {
          "alias": "GPT"
        },
        "google/gemini-3.1-pro-preview": {},
        "google/gemini-2.5-flash": {}
      },
      "model": {
        "primary": "google/gemini-2.5-flash"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": true
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "provider": "gemini",
        "enabled": true
      }
    }
  },
  "plugins": {
    "entries": {
      "whatsapp": {
        "enabled": true
      },
      "openai": {
        "enabled": true
      },
      "codex": {
        "enabled": true
      },
      "google": {
        "enabled": true,
        "config": {
          "webSearch": {
            "apiKey": "YOUR_GOOGLE_WEB_SEARCH_API_KEY"
          }
        }
      }
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "selfChatMode": true,
      "dmPolicy": "allowlist",
      "allowFrom": [
        "YOUR_PHONE_NUMBER"
      ],
      "groupAllowFrom": [
        "YOUR_PHONE_NUMBER"
      ]
    }
  },
  "auth": {
    "profiles": {
      "openai:api-key": {
        "provider": "openai",
        "mode": "api_key"
      },
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "providers": {
      "openai": {
        "agentRuntime": {
          "id": "openclaw"
        }
      }
    }
  },
  "skills": {
    "entries": {
      "browser-automation": {
        "enabled": true
      },
      "property-search": {
        "enabled": true
      }
    }
  }
}
